# Copy to .env — the runner loads it automatically (python-dotenv).
# Only the providers you actually run are required.

# OpenAI models (gpt-3.5-turbo, gpt-4o-mini, gpt-5.x)
OPENAI_API_KEY=

# OpenRouter models (Gemini 2.5 Flash, Qwen3-235B)
OPENROUTER_API_KEY=

# AWS Bedrock models (Claude, Llama, DeepSeek, Mistral).
# The runner refuses Bedrock runs without an explicit profile.
AWS_PROFILE=
AWS_REGION=us-east-1

# Optional spend guard: comma-separated AWS profile prefixes / account IDs
# that must never carry experiment spend.
# PSYCHBENCH_DENIED_AWS_PROFILE_PREFIXES=
# PSYCHBENCH_DENIED_AWS_ACCOUNT_IDS=
